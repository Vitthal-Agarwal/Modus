# Modus — optional API keys. All providers degrade gracefully to mocks if unset.

# Financial Modeling Prep — free tier key at https://site.financialmodelingprep.com/developer
FMP_API_KEY=

# FRED (Federal Reserve Economic Data) — free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Force all providers to mock mode (useful for deterministic demos)
MODUS_FORCE_MOCK=0

# FastAPI dev
MODUS_API_HOST=127.0.0.1
MODUS_API_PORT=8000
