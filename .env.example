# Modus — VC Audit Tool
# Copy this file to backend/.env and fill in your keys.
# Every provider degrades gracefully to the deterministic mock if its key is absent,
# so the full flow works with zero keys set.

# ── AI Research (primary research provider) ───────────────────────────────────
# Powers "Research any company" — Claude synthesizes sector, revenue, growth,
# margins, and last-round data from public sources.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Private-market comps ───────────────────────────────────────────────────────
# Octagon Agents API — 3M+ private companies, 500K+ funding rounds,
# 2M+ M&A transactions with EV/Revenue multiples.
# Free tier at https://octagonagents.com/
OCTAGON_API_KEY=

# ── Web-search fallback ────────────────────────────────────────────────────────
# Firecrawl — used when Octagon and yfinance both miss for peer multiples.
# Free tier at https://firecrawl.dev/
FIRECRAWL_API_KEY=

# ── Macro rates ───────────────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — 10-year Treasury yield (DGS10)
# used as the risk-free rate in WACC. Completely optional; yfinance ^TNX is
# used as a fallback if this key is absent.
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Demo / testing ────────────────────────────────────────────────────────────
# Set to 1 to force all providers to return deterministic mock fixtures even
# when live keys are set. Every output is byte-identical across runs.
MODUS_FORCE_MOCK=0

# ── FastAPI server ────────────────────────────────────────────────────────────
MODUS_API_HOST=127.0.0.1
MODUS_API_PORT=8000
